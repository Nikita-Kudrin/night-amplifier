{
  "name": "night-amplifier-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{js,vue}\""
  },
  "dependencies": {
    "vue": "^3.5.13",
    "lz4js": "^0.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "happy-dom": "^20.8.9",
    "prettier": "^3.8.1",
    "vite": "^6.4.1",
    "vitest": "^4.1.2"
  },
  "overrides": {
    "picomatch": "4.0.4",
    "brace-expansion@^2": "2.0.3",
    "brace-expansion@^5": "5.0.5"
  }
}
